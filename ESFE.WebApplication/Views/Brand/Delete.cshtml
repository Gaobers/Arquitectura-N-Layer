@model ESFE.BusinessLogic.DTOs.BrandResponse

@{
    ViewData["Title"] = "Eliminar";
}

<h1>Eliminar</h1>

<h3>¿Está seguro de que desea eliminar el registro?</h3>
<div>
    <h4>Marca</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Nombre
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BrandName)
        </dd>
    </dl>
    
    <form asp-action="Delete" asp-route-id="@Model.BrandId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BrandId" />

        <input type="submit" value="Eliminar" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-info">Cancelar</a>
    </form>
</div>