@model IEnumerable<ESFE.BusinessLogic.DTOs.ProductDTO>

@{
    ViewData["Title"] = "Listado de Productos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Gestión de Productos</h1>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nuevo Producto
        </a>
    </div>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Imagen</th>
                <th>Nombre del Producto</th>
                <th>Precio</th>
                <th>Marca</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center" style="width: 100px;">
                        @if (!string.IsNullOrEmpty(item.ImagenRuta))
                        {
                            <img src="@item.ImagenRuta" alt="@item.Nombre" 
                                 class="img-thumbnail" style="height: 60px; width: 60px; object-fit: cover;" />
                        }
                        else
                        {
                            <img src="/images/no-image.png" alt="Sin imagen" 
                                 class="img-thumbnail" style="height: 60px; width: 60px;" />
                        }
                    </td>
                    <td class="align-middle">@item.Nombre</td>
                    <td class="align-middle">@item.Precio.ToString("C")</td>
                    <td class="align-middle">@item.NombreMarca</td>
                    <td class="text-center align-middle">
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                <i class="bi bi-eye"></i> Ver
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                  onsubmit="return confirm('¿Estás seguro de eliminar este producto?');" 
                                  style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Borrar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>