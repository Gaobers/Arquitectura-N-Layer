@model ESFE.BusinessLogic.DTOs.ProductDTO

@{
    ViewData["Title"] = "Confirmar Eliminación";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="alert alert-danger shadow">
                <i class="bi bi-exclamation-triangle-fill display-4"></i>
                <h2 class="mt-3">¿Eliminar este producto?</h2>
                <p class="lead">Esta acción no se puede deshacer.</p>
                <hr />
                <div class="mb-4">
                    <img src="@Model.ImagenRuta" class="img-thumbnail mb-2" style="height: 150px;" />
                    <h4>@Model.Nombre</h4>
                    <p class="text-muted">Precio: @Model.Precio.ToString("C")</p>
                </div>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger btn-lg px-5">Sí, Eliminar</button>
                    <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>