@model ESFE.BusinessLogic.DTOs.UpdateUserRequest

@{
    ViewData["Title"] = "Editar";
}

<h1>Editar</h1>

<h4>Usuario</h4>
<hr />
<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    <!-- IMPORTANTE: Campo oculto para el ID del usuario -->
    <input type="hidden" asp-for="UserId" />

    <div class="row">
        <!-- Campo: Nombre -->
        <div class="form-group col-4">
            <label asp-for="UserName" class="control-label">Nombre</label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

        <!-- Campo: Usuario (Nickname) -->
        <div class="form-group col-3">
            <label asp-for="UserNickname" class="control-label">Usuario</label>
            <input asp-for="UserNickname" class="form-control" />
            <span asp-validation-for="UserNickname" class="text-danger"></span>
        </div>

        <!-- Campo: Roles -->
        <div class="form-group col-5">
            <label asp-for="RolId" class="control-label">Roles</label>
            <select asp-for="RolId" class="form-control" asp-items="ViewBag.RolId"></select>
            <span asp-validation-for="RolId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <!-- Campo: Password (Opcional en edición según tu lógica de negocio) -->
        <div class="form-group col-3">
            <label asp-for="UserPassword" class="control-label">Password</label>
            <input asp-for="UserPassword" type="password" class="form-control" />
            <span asp-validation-for="UserPassword" class="text-danger"></span>
        </div>

        <!-- Campo: Estatus -->
        <div class="form-group col-3">
            <label asp-for="UserStatus" class="control-label">Estatus</label>
            <select asp-for="UserStatus" class="form-control">
                <option value="True">ACTIVO</option>
                <option value="False">INACTIVO</option>
            </select>
            <span asp-validation-for="UserStatus" class="text-danger"></span>
        </div>
    </div>

    <hr />
    <div class="row">
        <div class="form-group mt-3">
            <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-info">Volver a la lista</a>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}